#!/bin/sh
#
# pre-push guard: never let .claude/ (config, memory, signing keys) reach GitHub.
#
# A leaked .claude/certificates/budget.key once hit public GitHub via a plain
# `git push github master` whose history contained the .claude commits. This
# hook aborts any push to a github.com remote if the pushed history touches
# .claude. The self-hosted origin (which intentionally tracks .claude) is not
# affected.
#
# Versioned in the repo at .githooks/. Activate per clone with:
#   git config core.hooksPath .githooks
#
# Args:  $1 = remote name, $2 = remote URL
# Stdin: <local ref> <local sha> <remote ref> <remote sha> per line

remote_url="$2"

# Only guard GitHub remotes.
case "$remote_url" in
	*github.com*) ;;
	*) exit 0 ;;
esac

z40=0000000000000000000000000000000000000000
status=0

while read -r local_ref local_sha remote_ref remote_sha; do
	# Skip branch deletions.
	[ "$local_sha" = "$z40" ] && continue

	# Pick the commit range to inspect. If the remote tip is unknown locally
	# (new branch, or object not fetched), scan the full pushed history.
	if [ "$remote_sha" = "$z40" ] || ! git cat-file -e "$remote_sha" 2>/dev/null; then
		range="$local_sha"
	else
		range="$remote_sha..$local_sha"
	fi

	if [ -n "$(git log --oneline "$range" -- .claude 2>/dev/null)" ]; then
		echo "" >&2
		echo "pre-push BLOCKED: '$local_ref' has .claude/ in its history." >&2
		echo "  Refusing to push it to GitHub ($remote_url)." >&2
		echo "  GitHub must never receive .claude (config, memory, signing keys)." >&2
		echo "  Push a .claude-free history instead (filter/cherry-pick onto github's clean base)." >&2
		echo "" >&2
		status=1
	fi
done

exit $status
